ai.mais.agency {
    @auth path /start /callback /logout /ping
    handle @auth {
        reverse_proxy 127.0.0.1:4180
    }

    handle {
        forward_auth 127.0.0.1:4180 {
            uri /auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email
        }
        reverse_proxy 127.0.0.1:9119
    }
}
