# Required: OAuth credentials for Yandex
# Get these at https://oauth.yandex.ru
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# Required: API key for Hermes Agent provider
OPENCODE_ZEN_API_KEY=sk-zen-your_key_here

# Optional: will be auto-generated if empty
# OAUTH2_PROXY_COOKIE_SECRET=
